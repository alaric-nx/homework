{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HomeworkParseResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_meaning_zh",
    "reference_answer",
    "explanation_zh",
    "key_vocabulary",
    "speak_units",
    "uncertainty"
  ],
  "properties": {
    "question_meaning_zh": {
      "type": "string",
      "minLength": 1
    },
    "reference_answer": {
      "type": "string",
      "minLength": 1
    },
    "explanation_zh": {
      "type": "string",
      "minLength": 1
    },
    "key_vocabulary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["word", "meaning_zh"],
        "properties": {
          "word": {
            "type": "string",
            "minLength": 1
          },
          "meaning_zh": {
            "type": "string",
            "minLength": 1
          },
          "ipa": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "speak_units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_type", "text"],
        "properties": {
          "unit_type": {
            "type": "string",
            "enum": ["word", "sentence"]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_review", "confidence"],
      "properties": {
        "requires_review": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": ["string", "null"]
        }
      }
    },
    "answer_placements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "text", "bbox_norm"],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 99
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "bbox_norm": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 4,
            "maxItems": 4
          },
          "font_size_ratio": {
            "type": ["number", "null"],
            "minimum": 0.005,
            "maximum": 0.2
          }
        }
      }
    },
    "ocr_result": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["text", "confidence"],
      "properties": {
        "text": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "image_width": {
          "type": ["integer", "null"]
        },
        "image_height": {
          "type": ["integer", "null"]
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": {"type": "string"},
              "bbox": {
                "type": ["array", "null"],
                "items": {"type": "number"},
                "minItems": 4,
                "maxItems": 4
              },
              "polygon": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {"type": "number"},
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "label": {"type": ["string", "null"]},
              "order": {"type": ["integer", "null"]},
              "page": {"type": ["integer", "null"]}
            }
          }
        }
      }
    }
  }
}
