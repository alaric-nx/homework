# 后端运行配置文件（显式可见）
# 修改本文件后，执行：./start_backend.sh

# =========================
# Web 服务启动参数（Uvicorn）
# =========================
# 监听地址（本机调试用 127.0.0.1；局域网访问可改 0.0.0.0）
SERVER_HOST=127.0.0.1
# 监听端口
SERVER_PORT=3000
# 是否开启热重载（开发环境 true，生产建议 false）
SERVER_RELOAD=true

# =========================
# 应用基础配置
# =========================
# 应用名（日志中会使用）
HW_APP_NAME=homework-backend
# 运行环境标识：dev / test / prod
HW_APP_ENV=dev
# 日志级别：DEBUG / INFO / WARNING / ERROR
HW_APP_LOG_LEVEL=INFO
# 日志输出位置：stdout / file / both
HW_APP_LOG_OUTPUT=file
# 文件日志路径（相对 backend 目录）
HW_APP_LOG_FILE=logs/backend.log

# =========================
# OpenCode 模型调用配置
# =========================
# 是否启用 opencode 调用（true 表示走真实模型；false 仅走兜底逻辑）
HW_OPENCODE_ENABLED=true
# opencode 可执行命令（建议填绝对路径，避免 PATH 差异）
HW_OPENCODE_CMD=/usr/local/nvm/versions/node/v24.14.0/bin/opencode
#HW_OPENCODE_CMD=/Users/y/.nvm/versions/node/v24.14.0/bin/opencode
# 模型名（留空表示使用 opencode 默认模型）
HW_OPENCODE_MODEL=
# 单次模型调用超时（秒）
HW_OPENCODE_TIMEOUT_SEC=60
# opencode 原始输入输出落盘目录（相对 backend 目录）
HW_OPENCODE_RAW_LOG_DIR=logs/opencode

# =========================
# OpenCode 出网代理配置
# =========================
# HTTP 代理地址
HW_PROXY_HTTP=http://127.0.0.1:7890
# HTTPS 代理地址
HW_PROXY_HTTPS=http://127.0.0.1:7890
# 通用代理地址（部分客户端读取 ALL_PROXY）
HW_PROXY_ALL=http://127.0.0.1:7890

# =========================
# OCR 配置（按顺序尝试 provider，成功即停止）
# =========================
# OCR provider 顺序（可选：paddle_cloud,rapidocr,paddleocr,tesseract,mock）
# 已设置为优先走你配置的 Paddle 云端 OCR
HW_OCR_PROVIDER_ORDER=paddle_cloud,rapidocr,paddleocr,tesseract,mock
# OCR 语言（当前后端默认英语链路，建议 en）
HW_OCR_LANG=en
# 是否允许通过 image_url 下载远程图片后再 OCR（true/false）
HW_OCR_FETCH_URL_ENABLED=true

# =========================
# PaddleOCR 云端 API 配置（你已提供）
# =========================
# 文档解析 API 地址（layout parsing 接口）
PADDLEOCR_DOC_PARSING_API_URL=https://5144tagefdi1je3a.aistudio-app.com/layout-parsing
# PaddleOCR 访问令牌
PADDLEOCR_ACCESS_TOKEN=e4748a45308442000337ae6835be0c73b9500214
# PaddleOCR 请求超时（秒）
PADDLEOCR_TIMEOUT=120
